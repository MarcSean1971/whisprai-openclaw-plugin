{
  "name": "@clawkit/clawkit-for-whisprai",
  "version": "0.1.5",
  "description": "ClawKit bridge that pairs OpenClaw with WhisprAI Connect My Computer.",
  "type": "module",
  "license": "MIT",
  "homepage": "https://whisprai.app",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MarcSean1971/clawkit-for-whisprai.git"
  },
  "bugs": {
    "url": "https://github.com/MarcSean1971/clawkit-for-whisprai/issues"
  },
  "keywords": [
    "clawkit",
    "openclaw",
    "whisprai",
    "archie",
    "ai-assistant",
    "local-agent",
    "computer-use",
    "private-assistant"
  ],
  "scripts": {
    "test": "node --test extract-agent-text.test.mjs",
    "pack:dry": "npm pack --dry-run"
  },
  "dependencies": {
    "openclaw": "^2026.4.29"
  },
  "engines": {
    "node": ">=22"
  },
  "files": [
    "README.md",
    "LICENSE",
    "SECURITY.md",
    "openclaw.plugin.json",
    "index.js",
    "extract-agent-text.js",
    "extract-agent-text.test.mjs",
    "docs"
  ],
  "exports": {
    ".": "./index.js"
  },
  "openclaw": {
    "extensions": ["./index.js"],
    "runtimeExtensions": ["./index.js"],
    "compat": {
      "pluginApi": ">=2026.3.24-beta.2",
      "minGatewayVersion": "2026.3.24-beta.2"
    },
    "build": {
      "openclawVersion": "2026.4.29",
      "pluginSdkVersion": "2026.4.29"
    }
  }
}
